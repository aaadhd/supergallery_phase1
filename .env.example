# Supabase: 현재 앱은 마운트 시 원격 작품 로드를 하지 않음 (시드 + localStorage만 사용).
# REST 헬퍼는 src/app/services/supabase*.ts 에 보관 — 나중에 다시 연동할 때 참고.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# (선택) 업로드 직후 피드에 바로 노출 — 비우면 검수 대기(pending) 후 /admin/content-review 승인
# VITE_UPLOAD_AUTO_APPROVE=true

# (선택) 커스텀 REST
# VITE_API_BASE_URL=https://your-api.example.com
