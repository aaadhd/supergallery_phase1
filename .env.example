# Supabase: 현재 앱은 마운트 시 원격 작품 로드를 하지 않음 (시드 + localStorage만 사용).
# REST 헬퍼는 src/app/services/supabase*.ts 에 보관 — 나중에 다시 연동할 때 참고.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# (선택) 데모·목업 편의: 업로드 직후 approved. 운영 원칙은 pending→검수이므로 프로덕션에서는 두지 말 것.
# VITE_UPLOAD_AUTO_APPROVE=true

# (선택) 커스텀 REST
# VITE_API_BASE_URL=https://your-api.example.com

# (선택) 어드민 /admin 접근 시 운영팀 역할 토글 생략 — CI·프리뷰만 (프로덕션 비권장)
# VITE_ADMIN_OPEN=true
